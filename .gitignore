# --- TerraLens Brain Logic ---
# Allow technical knowledge and grammar files
!/sandbox/compress_bridge/brain_data/**/*.txt
!/sandbox/compress_bridge/brain_data/**/*.json
!/sandbox/compress_bridge/brain_data/**/*.md

# Ignore the heavy neural state files (Sync these via USB/Drive)
/sandbox/compress_bridge/src/brain_weights.bin
/sandbox/compress_bridge/src/semantic_vocab.bin
/sandbox/compress_bridge/src/brain_config.bin
/sandbox/compress_bridge/src/*.exe
/sandbox/compress_bridge/bin/
/sandbox/compress_bridge/brain/
